<Window x:Class="WinToLin.views.SelectMode"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Icon="/Img/icon_small.png"
        d:DesignHeight="400" d:DesignWidth="400"
        Title="WinToLin" Height="450" Width="450">
    <Grid >
        <Grid.Background>
            <ImageBrush ImageSource="/Img/background/bg_square_hexes.png">
                <ImageBrush.Transform>
                    <RotateTransform Angle="0"/>
                </ImageBrush.Transform>
                <ImageBrush.Opacity>0.2</ImageBrush.Opacity>
            </ImageBrush>
        </Grid.Background>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="0.05*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="0.25*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Padding="0,25,0,0"
                   Style="{StaticResource TitleLabel}"
                   HorizontalAlignment="Center">

            <Run Text="Welcome to" />
            <Run Text="WinToLin" Style="{StaticResource TitleLabelAccent}" />
        </TextBlock>


        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.Background>
                <SolidColorBrush Opacity="0"/>
            </Grid.Background>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="35, 0, 15, 0">
                <TextBlock FontSize="15" Margin="0,0,0,20">• Easy way to switch to Linux</TextBlock>
                <TextBlock FontSize="15" Margin="0,0,0,20">• Bring over all your data</TextBlock>
                <TextBlock FontSize="15" Margin="0,0,0,20">• Autoinstall Linux alternatives for your Windows apps</TextBlock>
                <TextBlock FontSize="15" Margin="0,0,0,20">• It will feel like you never left</TextBlock>
                <TextBlock FontSize="15" Margin="0,0,0,20">• For beginners and advanced users</TextBlock>
            </StackPanel>

            <Image Grid.Column="1" Source="../Img/icon_big.png" Margin="0, 0, 35, 5" />
        </Grid>


        <!-- erklären was die zwei optionen machen -->
        <Button Grid.Row="3" Grid.Column="0" Height="60" Width="150" Click="OneClickTransferClicked">Transfer All</Button>
        <Button Grid.Row="3" Grid.Column="1" Height="60" Width="150" Click="CustomTransferClicked">Custom Transfer</Button>

        <TextBlock Style="{StaticResource DescriptionLabel}" Grid.Column="0" Grid.Row="4" HorizontalAlignment="Center"
                   Margin="15, -25, 0,0" Width="140">
            Move all your data with no manuel work
        </TextBlock>
        <TextBlock Style="{StaticResource DescriptionLabel}" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Center"
                   Margin="0, -25, 0,0" Width="140">
            Customize what you want to take over
        </TextBlock>
    </Grid>
</Window>