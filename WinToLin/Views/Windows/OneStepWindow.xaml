<Window x:Class="WinToLin.Views.Windows.OneStepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:conv="clr-namespace:WinToLin.Converters"
        mc:Ignorable="d"
        x:Name="RootWindow"
        d:DesignHeight="480"
        d:DesignWidth="460"
        Icon="/Img/icon_small.png"
        Title="WinToLin" Height="480" Width="460"
        Background="#FFFFFF">

    <Window.Resources>
        <conv:LogoToBackgroundConverter x:Key="LogoToBackgroundConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Linux Distribution Selection Grid (Constrained to 1 Row High) -->
        <Grid Grid.Row="0" Margin="16,12,16,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     x:Name="SearchBox"
                     Margin="0,0,0,8"
                     Padding="8,6"
                     Background="#F8FAFC"
                     Foreground="#0F172A"
                     BorderBrush="#E2E8F0"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged" />

            <ScrollViewer Grid.Row="1" Height="102" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="DistroList"
                              Foreground="#0F172A"
                              ItemsSource="{Binding ElementName=RootWindow, Path=FilteredDistroItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,10" Width="76" Height="76">
                                
                                <Border x:Name="SelectionFrame"
                                        BorderThickness="3"
                                        BorderBrush="Transparent"
                                        CornerRadius="14"
                                        Margin="-5" />

                                <Border x:Name="CardContent"
                                        CornerRadius="8"
                                        Background="{Binding ImagePath, Converter={StaticResource LogoToBackgroundConverter}}"
                                        MouseLeftButtonUp="CardBorder_MouseLeftButtonUp"
                                        Cursor="Hand">

                                    <Grid Margin="4,6,4,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Image Grid.Row="0"
                                               Source="{Binding ImagePath}"
                                               Width="26" Height="26"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality" />

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding RawName}"
                                                   Foreground="{StaticResource LightTextColor}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,4,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="SelectionFrame" Property="BorderBrush"
                                            Value="{Binding ImagePath, Converter={StaticResource LogoToBackgroundConverter}}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Row 1: USB Device Selection & Progress Tracking Interface -->
        <Grid Grid.Row="1" Margin="16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Select target USB flash drive:"
                       Foreground="#64748B"
                       Margin="2,0,0,8"
                       FontSize="12"
                       FontWeight="Medium"
                       TextWrapping="Wrap"/>

            <ListBox Grid.Row="1" 
                     x:Name="UsbList"
                     MaxHeight="56"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#0F172A"
                     SelectionMode="Single"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,6"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,10"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#CBD5E1"/>
                                            <Setter Property="Cursor" Value="Hand" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Viewbox Grid.Column="0" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#64748B" Data="M6,10h12v7c0,1.7-1.3,3-3,3H9c-1.7,0-3-1.3-3-3V10z M8,4h8v4H8V4z M10,6h1v1h-1V6z M13,6h1v1h-1V6z"/>
                                </Canvas>
                            </Viewbox>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#0F172A"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Letter}"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="2" 
                                    Background="#E0F2FE" 
                                    CornerRadius="4" 
                                    Padding="6,3" 
                                    VerticalAlignment="Center" 
                                    Margin="8,0,2,0">
                                <TextBlock Text="{Binding Size}"
                                           Foreground="#0369A1"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="2,4,0,0">
                <TextBlock x:Name="NoUsbText"
                           Text="No USB device detected. Please insert one."
                           Foreground="#DC2626"
                           FontSize="12"
                           FontWeight="Medium"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="SelectedUsbText"
                           Foreground="#059669"
                           FontSize="12"
                           FontWeight="Medium"/>
            </StackPanel>

            <!-- Pipeline Monitoring Layout Section -->
            <StackPanel x:Name="ExecutionStatusPanel" Grid.Row="3" Margin="2,10,2,0" Visibility="Collapsed">
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="ProgressText" Text="Waiting to begin..." Foreground="#475569" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ElementName=MainProgress, Path=Value, StringFormat={}{0:0}%}" Foreground="#3B82F6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                
                <ProgressBar x:Name="MainProgress" Height="6" Minimum="0" Maximum="100" Value="0" Background="#F1F5F9" Foreground="#3B82F6" BorderThickness="0">
                    <ProgressBar.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>

                <!-- Steps Tracking Box -->
                <ItemsControl x:Name="StepsControl" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="IndicatorDot" Grid.Column="0" Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBlock x:Name="StepNameText" Grid.Column="1" Text="{Binding Name}" Foreground="#94A3B8" FontSize="11"/>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="IndicatorDot" Property="Fill" Value="#3B82F6"/>
                                    <Setter TargetName="StepNameText" Property="Foreground" Value="#0F172A"/>
                                    <Setter TargetName="StepNameText" Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                    <Setter TargetName="IndicatorDot" Property="Fill" Value="#10B981"/>
                                    <Setter TargetName="StepNameText" Property="Foreground" Value="#10B981"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Row 2: Bottom Application Action Buttons Execution Interface -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
        
            <Button Grid.Column="0" 
                    x:Name="CreateIsoButton"
                    Content="Create ISO file" 
                    Click="CreateIsoButton_OnClick"
                    MinHeight="40"
                    Margin="30,12,15,20" 
                    Padding="0,8" 
                    FontSize="14"
                    FontWeight="SemiBold"
                    VerticalContentAlignment="Center"
                    IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="1" 
                    x:Name="MigrateButton"
                    Content="Migrate System" 
                    Click="MigrateButton_Click"
                    MinHeight="40"
                    Margin="15,12,30,20" 
                    Padding="0,8" 
                    FontSize="14"
                    FontWeight="SemiBold"
                    VerticalContentAlignment="Center"
                    IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
        
    </Grid>
</Window>