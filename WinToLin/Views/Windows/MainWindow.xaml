<Window x:Class="WinToLin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinToLin"
        Title="Custom Transfer" Height="550" Width="850"
        Icon="/Img/icon_small.png"
        UseLayoutRounding="True" SnapsToDevicePixels="True" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Border Grid.Row="0" BorderBrush="Black" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.25*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                    <Image Source="../img/icon_big.png" Width="40" Height="40" VerticalAlignment="Center" />
                    <TextBlock Text="WinToLin" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0" />
                </StackPanel>

                <!-- STEPS LIST -->


                <ItemsControl ItemsSource="{Binding Steps}" Grid.Column="1" HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- UniformGrid ensures each "cell" takes up equal parts of the total width -->
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- This outer container catches the click/hit area and handles centering -->
                            <Grid VerticalAlignment="Center">
                                <Border x:Name="StepBorder"
                                        BorderThickness="0,0,0,2"
                                        Padding="0,2"
                                        HorizontalAlignment="Center"
                                        BorderBrush="Transparent">
                                    <TextBlock x:Name="StepText"
                                               Text="{Binding Name}"
                                               Foreground="#AAAAAA"
                                               FontSize="13" />
                                </Border>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Current">
                                    <Setter TargetName="StepBorder" Property="BorderBrush" Value="#007ACC" />
                                    <Setter TargetName="StepText" Property="Foreground" Value="#007ACC" />
                                    <Setter TargetName="StepText" Property="FontWeight" Value="Bold" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsTaskDone}" Value="True">
                                    <Setter TargetName="StepBorder" Property="BorderBrush" Value="#FFD700" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                    <Setter TargetName="StepBorder" Property="BorderBrush" Value="#28A745" />
                                    <Setter TargetName="StepText" Property="Foreground" Value="#28A745" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>


            </Grid>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Row="1" x:Name="MainContent" />

        <!-- Footer Buttons -->

        <Border Grid.Row="2" BorderBrush="Black" BorderThickness="0,1,0,0">

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" x:Name="BackButton" Content="Back" HorizontalAlignment="Left" Width="120" Margin="20,10"
                        Click="GoBack_OnClick" Visibility="Hidden" />
                
                <TextBlock Grid.Column="1" x:Name="TaskText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                    
                </TextBlock>
                
                <Button Grid.Column="2" x:Name="GoNextButton" Content="Next" HorizontalAlignment="Right" Width="120" Margin="20,10"
                        Click="GoNext_OnClick" IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>

</Window>