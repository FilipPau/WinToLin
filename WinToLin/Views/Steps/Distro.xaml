<UserControl x:Class="WinToLin.Views.Steps.Distro"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WinToLin.Steps"
             xmlns:conv="clr-namespace:WinToLin.Converters"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="950">

    <UserControl.Resources>
        <conv:LogoToBackgroundConverter x:Key="LogoToBackgroundConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="DistroList" ItemsSource="{Binding DistroItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="20" x:Name="SquareContainer" 
                              Height="{Binding RelativeSource={RelativeSource Self}, Path=ActualWidth}">
                            
                            <Border x:Name="SelectionFrame"
                                    BorderThickness="2"
                                    BorderBrush="Transparent"
                                    CornerRadius="22"
                                    Margin="-12" />

                            <Border x:Name="CardContent"
                                    CornerRadius="15"
                                    Background="{Binding ImagePath, Converter={StaticResource LogoToBackgroundConverter}}"
                                    MouseLeftButtonUp="CardBorder_MouseLeftButtonUp"
                                    Cursor="Hand">

                                <Grid Margin="15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />

                                    <Image Grid.Row="0" Grid.Column="1"
                                           Source="{Binding ImagePath}"
                                           Width="40" Height="40"
                                           VerticalAlignment="Top"
                                           RenderOptions.BitmapScalingMode="HighQuality" />

                                    <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" 
                                                VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding UseCase}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,4,0,0"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.8" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="SelectionFrame" Property="BorderBrush" 
                                        Value="{Binding ImagePath, Converter={StaticResource LogoToBackgroundConverter}}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>