<Application x:Class="WinToLin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="/views/SelectMode.xaml">


    <Application.Resources>

        <!-- New Design -->

        <SolidColorBrush x:Key="BackgroundColor" Color="#FFFFFF" />

        <SolidColorBrush x:Key="DarkTextColor" Color="#000000" />
        <SolidColorBrush x:Key="LightTextColor" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentTextColor" Color="#a3a2a2" />

        <SolidColorBrush x:Key="InteractColor" Color="#3083DC" />
        <SolidColorBrush x:Key="ButtonHoverColor" Color="#2462A5" />
        <SolidColorBrush x:Key="ButtonNotActiveColor" Color="#a3a2a2" />

        <SolidColorBrush x:Key="AccentColor1" Color="#4E3187" />
        <SolidColorBrush x:Key="AccentColor2" Color="#F8FFE5" />
        <SolidColorBrush x:Key="TextAccentColor" Color="#7DDE92" />
        <SolidColorBrush x:Key="AccentColor5" Color="#2EBFA5" />

        <Style TargetType="TextBlock" x:Key="TitleLabel">
            <Setter Property="Foreground" Value="{StaticResource DarkTextColor}" />
            <Setter Property="FontSize" Value="35" />
            <Setter Property="FontFamily" Value="./Fonts/#Josefin Sans Bold" />
        </Style>

        <Style TargetType="Run" x:Key="TitleLabelAccent">
            <Setter Property="Foreground" Value="{StaticResource TextAccentColor}" />
            <Setter Property="FontSize" Value="35" />
            <Setter Property="FontFamily" Value="./Fonts/#Fredericka the Great" />
        </Style>


        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="./Fonts/#Josefin Sans Bold" />
        </Style>


        <Style TargetType="TextBlock" x:Key="DescriptionLabel">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="./Fonts/#Josefin Sans Bold" />
            <Setter Property="Foreground" Value="{StaticResource AccentTextColor}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>


        <!-- Advanced Styles -->

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InteractColor}" />
            <Setter Property="Foreground" Value="{StaticResource LightTextColor}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="10, 5" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                Padding="3">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource ButtonHoverColor}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource InteractColor}" />
                            </Trigger>
                            
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource ButtonNotActiveColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Minimal ScrollBar Buttons (Hidden) -->
        <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Thumb Style -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <!-- Rounded, subtle thumb to match the 'Storage Bar' design -->
                        <Border x:Name="ThumbVisual"
                                Background="#CBD5E0"
                                CornerRadius="4"
                                Margin="2,0" />
                        <ControlTemplate.Triggers>
                            <!-- Darkens slightly on hover to match button interactions -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbVisual" Property="Background" Value="#94A3B8" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbVisual" Property="Background" Value="#64748B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ScrollBar Redesign -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Track Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource ScrollBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource ScrollBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Advanced Styles End -->

        <!-- New Design End -->


    </Application.Resources>
</Application>