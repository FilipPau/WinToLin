<UserControl x:Class="WinToLin.Steps.Software"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="900">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Height="30"
                     Width="400"
                     Margin="0,0,0,10"
                     IsEnabled="False"
                     HorizontalAlignment="Center"
                     FontSize="14"
                     Padding="6"
                     Background="#202020"
                     Foreground="White"
                     BorderBrush="#555"
                     BorderThickness="1"
                     Grid.Column="0"
                     TextChanged="SearchBox_TextChanged"/>

            <CheckBox Grid.Column="1"
                      HorizontalAlignment="Left"
                      Content="Hide Random Win Stuff"
                      IsChecked="True"
                      Checked="HideRandomWindowsStuff_OnChecked"
                      Unchecked="HideRandomWindowsStuff_OnUnchecked"/>

        </Grid>

        <!-- SOFTWARE LIST -->

        <ListView x:Name="SoftwareList"
                  Grid.Row="1"
                  Margin="40,0,40,0"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.CanContentScroll="False"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling">

            <ListView.ItemContainerStyle>

                <Style TargetType="ListViewItem">

                    <Setter Property="HorizontalContentAlignment"
                            Value="Stretch"/>

                    <Setter Property="Template">

                        <Setter.Value>

                            <ControlTemplate TargetType="ListViewItem">

                                <ContentPresenter/>

                            </ControlTemplate>

                        </Setter.Value>

                    </Setter>

                </Style>

            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>

                <DataTemplate>

                    <Border Padding="12"
                            BorderBrush="#262626"
                            BorderThickness="0,0,0,1">

                        <StackPanel ToolTip="{Binding InstallPath}">

                            <!-- WINDOWS APP -->

                            <Grid Height="45">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <CheckBox Width="20"
                                              Height="20"
                                              Margin="25,0,0,0"
                                              IsChecked="{Binding Install}"
                                              Visibility="{Binding ShowMainCheckbox}"
                                              IsEnabled="{Binding CanInstall}"
                                              Checked="Software_Checked"
                                              Unchecked="Software_Unchecked"/>

                                    <Image Source="{Binding Icon}"
                                           Width="28"
                                           Height="28"
                                           Margin="20,0,10,0"/>

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="350"/>

                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="10,4"
                                        Margin="10,0,25,0"
                                        CornerRadius="6"
                                        VerticalAlignment="Center">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Gray"/>

                                            <Style.Triggers>

                                                <!-- Native Linux -->
                                                <DataTrigger Binding="{Binding CompatibilityCategory}" Value="Native">
                                                    <Setter Property="Background" Value="#1F7A3E"/>
                                                </DataTrigger>

                                                <!-- Linux Alternative -->
                                                <DataTrigger Binding="{Binding CompatibilityCategory}" Value="Alternative">
                                                    <Setter Property="Background" Value="#E6BE32"/>
                                                </DataTrigger>

                                                <!-- Unknown -->
                                                <DataTrigger Binding="{Binding CompatibilityCategory}" Value="Unknown">
                                                    <Setter Property="Background" Value="#FF6600"/>
                                                </DataTrigger>

                                                <!-- Steam -->
                                                <DataTrigger Binding="{Binding CompatibilityCategory}" Value="Steam">
                                                    <Setter Property="Background" Value="#1F7A3E"/>
                                                </DataTrigger>

                                                <!-- Steam AntiCheat -->
                                                <DataTrigger Binding="{Binding CompatibilityCategory}" Value="AntiCheat">
                                                    <Setter Property="Background" Value="#E6BE32"/>
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="{Binding Compatibility}"
                                               FontSize="13"
                                               Foreground="White"/>

                                </Border>

                            </Grid>

                            <!-- ALTERNATIVES HEADER -->

                            <TextBlock Text="Linux Alternatives"
                                       Foreground="#BBBBBB"
                                       Margin="70,6,0,8"
                                       FontSize="13"
                                       Visibility="{Binding ShowAlternatives}"/>

                            <!-- ALTERNATIVE CARDS -->

                            <ItemsControl ItemsSource="{Binding Alternatives}">

                                <ItemsControl.ItemsPanel>

                                    <ItemsPanelTemplate>

                                        <WrapPanel Margin="70,0,0,10"/>

                                    </ItemsPanelTemplate>

                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Border Width="200"
                                                Height="75"
                                                Margin="5"
                                                Padding="10"
                                                Background="#1E1E1E"
                                                CornerRadius="8"
                                                BorderBrush="#2A2A2A"
                                                BorderThickness="1">

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsSelected}"
                                                          Checked="Alternative_Checked"/>

                                                <Image Grid.Column="1"
                                                       Source="{Binding Icon}"
                                                       Width="24"
                                                       Height="24"
                                                       VerticalAlignment="Center"/>

                                                <StackPanel Grid.Column="2"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center">

                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="14"/>

                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#AAAAAA"
                                                               FontSize="11"/>

                                                </StackPanel>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </StackPanel>

                    </Border>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

        <!-- LOADING -->

        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Background="#F0101010"
              Visibility="Visible">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <ProgressBar IsIndeterminate="True"
                             Width="150"
                             Height="4"
                             Foreground="#2E7DFF"
                             Background="#333"
                             BorderThickness="0"/>

                <TextBlock Text="Scanning Installed Software..."
                           Foreground="White"
                           FontSize="14"
                           Margin="0,15,0,0"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Grid>

    </Grid>
</UserControl>