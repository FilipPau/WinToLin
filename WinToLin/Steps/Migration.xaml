<UserControl x:Class="WinToLin.Steps.Migration"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <Grid Margin="20">

        <!-- 🔥 AUTO SCALE ROOT -->
        <Viewbox Stretch="Uniform">

            <Grid Width="900">

                <StackPanel>

                    <!-- STORAGE -->
                    <Border Background="#1B1F28"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,15">

                        <StackPanel>

                            <TextBlock Text="💾 Storage Usage"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <!-- BAR -->
                            <Grid Height="28" Background="#2D3445">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="IsoColumn"/>
                                    <ColumnDefinition x:Name="BackupColumn"/>
                                    <ColumnDefinition x:Name="FreeColumn"/>
                                </Grid.ColumnDefinitions>

                                <!-- ISO -->
                                <Border Grid.Column="0" Background="#4A90E2">
                                    <TextBlock x:Name="IsoText"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- BACKUP -->
                                <Border Grid.Column="1" Background="#50C878">
                                    <TextBlock x:Name="BackupText"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- FREE -->
                                <Border Grid.Column="2" Background="#777777">
                                    <TextBlock x:Name="FreeText"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- STEPS -->
                    <Border Background="#1B1F28"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,15">

                        <StackPanel>

                            <TextBlock Text="📦 Migration Steps"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"
                                       HorizontalAlignment="Center"/>

                            <ItemsControl x:Name="StepsList">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6"
                                                Padding="12"
                                                CornerRadius="10">

                                            <Border.Style>
                                                <Style TargetType="Border">

                                                    <Setter Property="Background" Value="#2D3445"/>

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#4A90E2"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                            <Setter Property="Background" Value="#50C878"/>
                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>

                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- PROGRESS -->
                    <ProgressBar x:Name="MainProgress"
                                 Height="20"
                                 Margin="0,0,0,5"/>

                    <TextBlock x:Name="ProgressText"
                               Foreground="#AAAAAA"
                               HorizontalAlignment="Center"/>

                    <Button Content="Migrate"
                            Height="40"
                            Width="120"
                            Margin="0,10,0,10"
                            HorizontalAlignment="Center"
                            Click="Migrate_Click"/>

                </StackPanel>

            </Grid>
        </Viewbox>

    </Grid>
</UserControl>