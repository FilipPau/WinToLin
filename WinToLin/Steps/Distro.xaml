<UserControl x:Class="WinToLin.Steps.Distro"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="DistroList">

                <!-- 4 cards per row -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Card with inner padding -->
                        <Border x:Name="CardBorder"
                                BorderBrush="Black" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Margin="5" 
                                Padding="10"
                                Height="180"
                                Background="#2B2B2B"
                                MouseLeftButtonUp="CardBorder_MouseLeftButtonUp">

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#2B2B2B"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#35353C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <!-- Inner padding container -->
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Logo top-left -->
                                <Image Source="{Binding ImagePath}" 
                                       Width="40" Height="40"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Left"
                                       Margin="0,0,8,0"/>

                                <!-- Name top-right -->
                                <TextBlock Text="{Binding Name}" 
                                           FontWeight="Bold"
                                           FontSize="14"
                                           VerticalAlignment="Top"
                                           HorizontalAlignment="Right"
                                           Grid.Column="1"/>

                                <!-- Middle: Base and UseCase -->
                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Margin="5">
                                    <TextBlock Text="{Binding Base, StringFormat=Based on {0}}"
                                               FontSize="10"
                                               Foreground="#A0A0A0"
                                               TextAlignment="Center"
                                               Margin="0,2,0,2"/>
                                    <TextBlock x:Name="UseCaseText"
                                               Text="{Binding UseCase}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#E0E0E0"
                                               TextAlignment="Center"
                                               Opacity="1"
                                               Margin="0,4,0,2"/>
                                </StackPanel>

                                <!-- Description fades in below middle row -->
                                <TextBlock x:Name="DescriptionText"
                                           Text="{Binding Description}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Opacity="0"
                                           Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Margin="5,4,5,0"
                                           TextAlignment="Center"
                                           Foreground="#E0E0E0"/>
                            </Grid>

                            <!-- Hover animations -->
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="UseCaseText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="DescriptionText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="UseCaseText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="DescriptionText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>