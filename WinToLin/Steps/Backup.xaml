<UserControl x:Class="WinToLin.Steps.Backup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- PERSONAL FILES -->
        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" CornerRadius="5" Background="#333">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- Scrollable content -->
                </Grid.RowDefinitions>

                <TextBlock Text="Personal Files"
                           FontSize="16"
                           Foreground="White"
                           Margin="6,6,6,6" />

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="6">
                    <ItemsControl x:Name="PersonalFilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6" Margin="0,0,0,6" CornerRadius="5">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- Checkbox -->
                                            <ColumnDefinition Width="Auto" />  <!-- Icon (optional) -->
                                            <ColumnDefinition Width="*" />     <!-- Text -->
                                            <ColumnDefinition Width="Auto" />  <!-- Button -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding Selected}"
                                                  Margin="0,0,6,0" />


                                        <StackPanel Grid.Column="2" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Name}" Foreground="White" />
                                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#AAA" />
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Content="Open"
                                                Width="70"
                                                Height="24"
                                                Click="OpenFolder_Click"
                                                Tag="{Binding Path}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- APPLICATION DATA -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,5,0" CornerRadius="5" Background="#333">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Application Data"
                           FontSize="16"
                           Foreground="White"
                           Margin="6,6,6,6" />

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="6">
                    <ItemsControl x:Name="AppDataList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6" Margin="0,0,0,6" Background="#222" CornerRadius="5">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- Checkbox -->
                                            <ColumnDefinition Width="Auto" />  <!-- Icon (optional) -->
                                            <ColumnDefinition Width="*" />     <!-- Text -->
                                            <ColumnDefinition Width="Auto" />  <!-- Button -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding Selected}"
                                                  Margin="0,0,6,0" />


                                        <StackPanel Grid.Column="2" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Name}" Foreground="White" />
                                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#AAA" />
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Content="Open"
                                                Width="70"
                                                Height="24"
                                                Click="OpenFolder_Click"
                                                Tag="{Binding Path}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- CUSTOM LOCATIONS (Right Panel) -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="5,0,0,0" CornerRadius="5" Background="#333">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Custom Locations"
                           FontSize="16"
                           Foreground="White"
                           Margin="6,6,6,6" />

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="6">
                    <ItemsControl x:Name="CustomLocationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6" Margin="0,0,0,6" Background="#222" CornerRadius="5">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- Checkbox -->
                                            <ColumnDefinition Width="Auto" />  <!-- Icon (optional) -->
                                            <ColumnDefinition Width="*" />     <!-- Text -->
                                            <ColumnDefinition Width="Auto" />  <!-- Button -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding Selected}"
                                                  Margin="0,0,6,0"
                                                  Checked="BackupItem_Checked"
                                                  Unchecked="BackupItem_Unchecked"/>


                                        <StackPanel Grid.Column="2" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Name}" Foreground="White" />
                                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#AAA" />
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Content="Open"
                                                Width="70"
                                                Height="24"
                                                Click="OpenFolder_Click"
                                                Tag="{Binding Path}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Content="Add Folder"
                        Width="150"
                        Height="32"
                        Margin="6,10,6,6"
                        Click="AddFolder_Click" />
            </Grid>
        </Border>

        <!-- LOADING OVERLAY -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Grid.ColumnSpan="3"
              Background="#AA101010"
              Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="150"
                             Height="4"
                             Foreground="#2E7DFF"
                             Background="#333"
                             BorderThickness="0" />
                <TextBlock Text="Loading backup locations..."
                           Foreground="White"
                           FontSize="14"
                           Margin="0,15,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>