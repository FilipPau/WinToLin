<Window x:Class="WinToLin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinToLin"
        mc:Ignorable="d"
        ResizeMode="NoResize"


        
        UseLayoutRounding="True"
        SnapsToDevicePixels="True" 
        
        Title="MainWindow" Height="550" Width="950">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>
        
        
        <Grid Grid.Row="1" Grid.ColumnSpan="3" x:Name="StepsListGrid"></Grid>
        
        <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            
            <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="0, 0, 20, 0" Source="./img/WinToLinLogo.png" HorizontalAlignment="Right"></Image>

            <Label Grid.Column="1" Grid.Row="0" Padding="0" VerticalAlignment="Bottom" FontSize="25">WinToLin</Label>
            <Label Grid.Column="1" Grid.Row="1" Padding="0" VerticalAlignment="Top" FontSize="15">Easy way to switch from Windows to Linux</Label>
            
        </Grid>
        

        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
        
        
        <Grid Grid.Row="2" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="3"> 
            <ContentControl x:Name="MainContent"></ContentControl>
        </Grid>

        <Grid Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3">
            <Button x:Name="GoNextButton" Margin="10" Width="180" HorizontalAlignment="Right" Click="GoNext_OnClick">Next</Button>
            
            <Button Margin="10" Width="180" HorizontalAlignment="Left" Click="GoBack_OnClick" Visibility="Hidden" x:Name="BackButton">Back</Button>
        </Grid>
    </Grid>
</Window>
